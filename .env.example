# ============================================================
#  Copy to ".env" and fill in. cp .env.example .env
# ============================================================

# ---- Image provider ----------------------------------------
# "gemini" (default — takes BOTH selfies as references in one call)
# or "replicate" (single-image Flux Kontext fallback).
PROVIDER=gemini

# Gemini (Nano Banana) — primary provider.
# https://ai.google.dev/gemini-api/docs/image-generation
GEMINI_API_KEY=
# Leave UNSET to use the code default (gemini-3.1-flash-image — the 2026-06-10
# bake-off winner, 1/20 fails). Do NOT set gemini-2.5-flash-image: it scored
# 12-16/20 embarrassing failures (cut-and-paste composites, slimmed faces).
# GEMINI_MODEL=
# Both uploaded selfies are passed as references (cap on how many we send).
GEMINI_MAX_REFS=2

# Replicate (optional fallback only) — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-kontext-pro
# Text-to-image model used by scripts/gen-bird-refs.js (Bird ID card images):
REF_MODEL=black-forest-labs/flux-1.1-pro

# ---- Stripe ($1 paywall) -----------------------------------
# Use TEST keys first: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Optional: webhook signing secret if you wire up the webhook
STRIPE_WEBHOOK_SECRET=
# Price in cents (100 = $1.00)
PRICE_CENTS=100
# Public base URL for Stripe redirects (no trailing slash).
# Leave blank locally — the server infers it from the request.
PUBLIC_URL=

# ---- App ---------------------------------------------------
PORT=3000
# Successful generations per IP per day
DAILY_CAP=20
# Global (all IPs) jobs per day. Gemini Tier 1 = 1,000 requests/day on the image
# model; a job is 5 calls + retries → 170 stays under it. Raise after Tier 2.
GLOBAL_DAILY_CAP=170
# Max simultaneous Gemini calls across ALL jobs (Tier 1 = 100 RPM). Raise after Tier 2.
GLOBAL_CONCURRENCY=15
# Minimum upload dimension (px). 768 blocks remorse-inducing tiny photos; 1024 is stricter.
MIN_IMAGE_DIM=768
# Looks generated in parallel per purchase (5 looks total)
CONCURRENCY=3
# Secret for the review-approval admin endpoints (leave blank to disable admin)
ADMIN_KEY=

# Beta codes that skip payment (comma-separated, case-insensitive). Blank = none.
FREE_CODES=

# ---- Email delivery (Resend) -------------------------------
# Emails users their 5 headshots on completion. Blank = no email sent.
RESEND_API_KEY=
# Must be a verified sender on your Resend domain:
EMAIL_FROM=Headshots with a Bird <noreply@headshotswithabird.com>

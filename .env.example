# ============================================================
#  Copy to ".env" and fill in. cp .env.example .env
# ============================================================

# ---- Image provider ----------------------------------------
# "replicate" (current default, single image, $0.04/img) or "gemini"
PROVIDER=replicate

# Replicate — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-kontext-pro

# ---- Locked bird (reference image) -------------------------
# When a reference image exists in public/birds/<id>.jpg, the bird is
# generated from THAT image (consistent + matches the Bird ID).
USE_BIRD_REF=true
# Multi-image model that takes selfie + bird reference:
REPLICATE_MULTI_MODEL=flux-kontext-apps/multi-image-kontext-max
# If that model's input param names differ, override here:
# REPLICATE_IMG1_KEY=input_image_1
# REPLICATE_IMG2_KEY=input_image_2
# Text-to-image model used by scripts/gen-bird-refs.js:
REF_MODEL=black-forest-labs/flux-1.1-pro

# Gemini (fallback / higher likeness via multi-reference)
GEMINI_API_KEY=
# Regular Nano Banana ≈ $0.039/img. Nano Banana Pro = gemini-3-pro-image-preview ≈ $0.134/img.
# Verify the exact current model name in Google's docs.
GEMINI_MODEL=gemini-2.5-flash-image
GEMINI_MAX_REFS=2
# To A/B test Gemini instead of Replicate, set PROVIDER=gemini above.

# ---- Stripe ($1 paywall) -----------------------------------
# Use TEST keys first: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Optional: webhook signing secret if you wire up the webhook
STRIPE_WEBHOOK_SECRET=
# Price in cents (100 = $1.00)
PRICE_CENTS=100
# Public base URL for Stripe redirects (no trailing slash).
# Leave blank locally — the server infers it from the request.
PUBLIC_URL=

# ---- App ---------------------------------------------------
PORT=3000
# Successful generations per IP per day
DAILY_CAP=20
# Minimum upload dimension (px). 768 blocks remorse-inducing tiny photos; 1024 is stricter.
MIN_IMAGE_DIM=768
# Images generated in parallel per purchase (5 looks)
CONCURRENCY=3
# Secret for the review-approval admin endpoints (leave blank to disable admin)
ADMIN_KEY=

# Beta codes that skip payment (comma-separated, case-insensitive). Blank = none.
FREE_CODES=

# ---- Email delivery (Resend) -------------------------------
# Emails users their 5 headshots on completion. Blank = no email sent.
RESEND_API_KEY=
# Must be a verified sender on your Resend domain:
EMAIL_FROM=Headshots with a Bird <noreply@headshotswithabird.com>

# ---- Output post-processing (de-AI-sheen) ------------------
ENHANCE=true        # set false to turn off
CONTRAST_PCT=4      # +4% contrast
SHARPEN_K=0.1       # mild sharpen strength (no standard %; raise for more bite)
JPEG_QUALITY=92
# CodeFormer face-restoration pass (~$0.0055/img) — sharpens faces, removes AI mush
RESTORE=true
RESTORE_MODEL=sczhou/codeformer
